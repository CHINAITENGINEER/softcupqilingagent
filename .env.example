# RAG + Milvus deployment template
# Copy to .env for local tooling only. Spring Boot reads OS environment variables,
# so import this file into your shell or CI environment before starting the app.

# Secrets: store these in CI/CD secret management, never commit real values.
SAFEOPS_RAG_MILVUS_TOKEN=
SAFEOPS_RAG_EMBEDDING_API_KEY=

# Milvus connection and collection
SAFEOPS_RAG_MILVUS_URI=http://localhost:19530
SAFEOPS_RAG_MILVUS_COLLECTION=safeops_knowledge
SAFEOPS_RAG_MILVUS_DIMENSION=1536
SAFEOPS_RAG_MILVUS_METRIC_TYPE=cosine
SAFEOPS_RAG_MILVUS_AUTO_CREATE_COLLECTION=false
SAFEOPS_RAG_MILVUS_AUTO_LOAD_COLLECTION=true
SAFEOPS_RAG_MILVUS_VALIDATE_INDEX=true

# Index strategy: autoindex, hnsw, or ivf-flat
SAFEOPS_RAG_MILVUS_INDEX_TYPE=hnsw

# HNSW build/search parameters
SAFEOPS_RAG_MILVUS_HNSW_M=16
SAFEOPS_RAG_MILVUS_HNSW_EF_CONSTRUCTION=200
SAFEOPS_RAG_MILVUS_HNSW_EF=64

# IVF_FLAT build/search parameters
SAFEOPS_RAG_MILVUS_IVF_FLAT_NLIST=128
SAFEOPS_RAG_MILVUS_IVF_FLAT_NPROBE=16

# OpenAI-compatible embedding provider
SAFEOPS_RAG_EMBEDDING_BASE_URL=http://localhost:11434/v1
SAFEOPS_RAG_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval limits
SAFEOPS_RAG_MAX_RESULTS=5
SAFEOPS_RAG_CONTEXT_MAX_LENGTH=2000
SAFEOPS_RAG_SNIPPET_MAX_LENGTH=500

# Real Milvus integration tests (disabled by default)
SAFEOPS_RAG_MILVUS_IT=false
SAFEOPS_RAG_MILVUS_IVF_FLAT_IT=false
SAFEOPS_RAG_MILVUS_KEEP_COLLECTION=false
